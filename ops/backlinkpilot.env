HOST=0.0.0.0
PORT=3000
WORKER_INTERVAL=30
HEALTHCHECK_PATH=/api/healthz
HEALTHCHECK_RETRIES=5
HEALTHCHECK_RETRY_DELAY=2
NEXT_TELEMETRY_DISABLED=1
