BACKLINKPILOT_ROOT=/root/backlinkpilot
BACKLINK_WORKSPACE_ROOT=/root/backlink_sender
BACKLINK_WORKSPACE_DATA_ROOT=/root/.local/share/backlink_sender
BACKLINKPILOT_STATE_ROOT=/root/.local/state/backlinkpilot
BACKLINKPILOT_ALERT_DIR=/root/backlink_sender/outbox/system-recovery-alerts
BACKLINKPILOT_SNAPSHOT_RETENTION_DAYS=14
BACKLINKPILOT_MIN_SNAPSHOTS=96
BACKLINKPILOT_ALERT_RETENTION_DAYS=45
BACKLINKPILOT_DASHBOARD_ROOT=/root/.local/state/backlinkpilot/dashboard
BACKLINKPILOT_DASHBOARD_HOST=127.0.0.1
BACKLINKPILOT_DASHBOARD_PORT=3001
POPWL_DIR=/root/backlink_sender/operations/backlinks/automation/popWL
BACKLINKS_ROOT=/root/backlink_sender/operations/backlinks
